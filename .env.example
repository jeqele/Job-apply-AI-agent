# Job source API keys (register at the provider sites below)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
REED_API_KEY=

# Optional: custom Chrome binary path
# CHROME_BINARY=C:\Program Files\Google\Chrome Dev\Application\chrome.exe

# SMTP settings for sending application emails (CV + cover letter)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true
# Optional: override the From address (defaults to profile email or SMTP_USER)
# SMTP_FROM=your.email@gmail.com
