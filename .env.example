# Job source API keys (register at the provider sites below)
# Arbeitnow public API requires no key: https://www.arbeitnow.com/api/job-board-api
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
REED_API_KEY=

# Scraper rate limiting (helps avoid 429 errors during batch searches)
# SCRAPE_MIN_INTERVAL_SECONDS=2.0
# SCRAPE_MAX_RETRIES=3
# SCRAPE_BACKOFF_BASE_SECONDS=2.0
# BATCH_SEARCH_DELAY_SECONDS=1.0
# MAX_BATCH_SEARCH_COMBINATIONS=100
# BATCH_QUEUE_MAX_COMBINATIONS_PER_JOB=50
# BATCH_WORKER_POLL_SECONDS=5
# Minimum wait between finishing one queue job and claiming the next (0 disables)
# BATCH_WORKER_INTER_JOB_INTERVAL_SECONDS=3600

# LinkedIn MCP sidecar (https://github.com/stickerdaniel/linkedin-mcp-server)
# Start locally: scripts/start-linkedin-mcp.ps1  (or the .sh script on macOS/Linux)
# One-time login: uvx mcp-server-linkedin@latest --login
# LINKEDIN_MCP_ENABLED=true
# LINKEDIN_MCP_URL=http://127.0.0.1:8765/mcp
# LINKEDIN_MCP_PORT=8765
# LINKEDIN_MCP_MAX_PAGES=1
# LINKEDIN_MCP_DETAIL_DELAY_SECONDS=2.0
# LINKEDIN_MCP_BATCH_DELAY_SECONDS=30
# LINKEDIN_MCP_HTTP_TIMEOUT=60
# LINKEDIN_MCP_SSE_TIMEOUT=300

# Optional: custom Chrome binary path
# CHROME_BINARY=C:\Program Files\Google\Chrome Dev\Application\chrome.exe

# Shared SQLite database (web UI and all workers must use the same absolute path)
# JOB_APPLY_AI_DB=/var/lib/job-apply-ai/jobs.db

# OAuth for sending application emails (app-level credentials — user accounts connect via /profile)
# Google Cloud Console → APIs & Services → Credentials → OAuth client (Web application)
# Enable Gmail API. Redirect URI example: http://127.0.0.1:5000/profile/oauth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:5000/profile/oauth/google/callback

# Azure Portal → App registrations → New registration → Web redirect URI
# API permissions: Mail.Send, User.Read, offline_access
# Redirect URI example: http://127.0.0.1:5000/profile/oauth/microsoft/callback
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
# MICROSOFT_OAUTH_REDIRECT_URI=http://127.0.0.1:5000/profile/oauth/microsoft/callback
# MICROSOFT_OAUTH_AUTHORITY=https://login.microsoftonline.com/common

# Ollama (local LLM for CV generation and chat editing)
# LLM_PROVIDER=ollama
# LLM_FAST_PROVIDER=ollama
# LLM_MAIN_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_CV_MODEL=gemma4:e4b
# OLLAMA_CV_FAST_MODEL=gemma4:e4b
# OLLAMA_NUM_PREDICT=8192

# FreeLLMAPI (local router — start the server before using this provider)
# LLM_PROVIDER=freellmapi
# FREELLMAPI_API_KEY=freellmapi-...
# FREELLMAPI_BASE_URL=http://localhost:3001/v1
# FREELLMAPI_CV_MODEL=auto
# FREELLMAPI_CV_FAST_MODEL=auto

# Alibaba Cloud Model Studio (Qwen via OpenAI-compatible DashScope API)
# LLM_PROVIDER=alibaba
# LLM_FAST_PROVIDER=ollama
# LLM_MAIN_PROVIDER=alibaba
# DASHSCOPE_API_KEY=sk-...
# ALIBABA_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# ALIBABA_CV_MODEL=qwen-plus
# ALIBABA_CV_FAST_MODEL=qwen-turbo
# ALIBABA_MAX_TOKENS=8192
# ALIBABA_MODEL_MODE=fixed
# Comma-separated models for round_robin or auto: qwen-turbo, qwen-plus, qwen-max
